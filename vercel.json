{
  "version": 2,
  "builds": [
    {
      "src": "src/ui/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/ui/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/ui/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/src/ui/$1"
    }
  ],
  "env": {
    "PORT": "3000"
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build:ui"
}
