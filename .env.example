# VeilTrader Environment Configuration

# Bankr LLM Gateway (https://bankr.bot)
BANKR_API_KEY=your_bankr_api_key_here

# Uniswap Developer API (https://developer.uniswap.org)
UNISWAP_API_KEY=your_uniswap_api_key_here

# Wallet Configuration (DO NOT COMMIT - keep secret)
PRIVATE_KEY=your_private_key_here

# Network Configuration
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
CHAIN_ID=84532

# Agent Configuration
AGENT_NAME=Stealth
AGENT_ID=your_agent_id_here
TEAM_ID=your_team_id_here

# Contract Addresses (Base Sepolia)
VEILTRADER_CONTRACT=0x0c7435e863D3a3365FEbe06F34F95f4120f71114
ERC8004_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Risk Parameters
MAX_SLIPPAGE=0.005
MIN_PROFIT_THRESHOLD=0.01
RISK_TOLERANCE=medium

# Cycle Interval (minutes between trading cycles)
CYCLE_INTERVAL=5

# Etherscan/Blockscout API Key
ETHERSCAN_API_KEY=your_blockscout_api_key_here

# Metadata for ERC-8004 registration
METADATA_URI=ipfs://QmYourMetadataHash
DOMAIN=your-domain.example.com

# ====================
# EXTENSIONS (Optional)
# ====================

# Olas Marketplace (for Olas prizes)
OLAS_API_KEY=your_olas_api_key

# Status Network (for Go Gasless prize)
STATUS_RPC_URL=https://sepoliarpc.status.network
STATUS_CHAIN_ID=299333333420
ENABLE_STATUS_NETWORK=false

# Lido (for stETH Treasury & Lido MCP prizes)
STETH_ADDRESS=0xc58d696aBd4633fC27Dd9D5C338242Cc62dC82A7
WSTETH_ADDRESS=0xFc2001aEdB3CFeD24a3C1DdD6B8d7c8b0acD2a2
ENABLE_STETH=false
ENABLE_LIDO_MCP=false

# OpenServ (for OpenServ prizes)
OPENSERV_API_KEY=your_openserv_api_key

# Filecoin Storage (for Agentic Storage prizes)
FILECOIN_API_KEY=your_filecoin_api_key

# ENS (for ENS Identity/Communication prizes)
ENABLE_ENS=false

# Celo (for Best Agent on Celo prize)
ENABLE_CELO=false
CELO_TESTNET=true
CELO_AUTO_EXECUTE=false
